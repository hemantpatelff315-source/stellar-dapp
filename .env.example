# ─────────────────────────────────────────────────────────────
# StellarFund — frontend environment template.
# Copy to frontend/.env.local and fill in after running scripts/deploy.sh
# (deploy.sh generates this file automatically).
# ─────────────────────────────────────────────────────────────

# Network: testnet | mainnet
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Soroban RPC endpoint
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Network passphrase used when signing transactions
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Native XLM Stellar Asset Contract (testnet default)
NEXT_PUBLIC_NATIVE_TOKEN=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC

# Deployed contract IDs (filled in by deploy.sh)
NEXT_PUBLIC_FACTORY_ID=
NEXT_PUBLIC_CAMPAIGN_ID=
NEXT_PUBLIC_TREASURY_ID=
